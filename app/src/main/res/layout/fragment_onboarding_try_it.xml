<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:paddingHorizontal="24dp"
    android:paddingTop="24dp"
    android:paddingBottom="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:layout_marginTop="16dp">

            <com.govorun.lite.overlay.BubbleView
                android:id="@+id/tryBubble"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center" />
        </FrameLayout>

        <!-- CTA lives directly under the bubble: the arrow of attention goes
             bird → instruction → result card, which is the only logical
             reading order when the bird is the tap target. -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tryHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:minLines="2"
            android:text="@string/onb_try_tap_to_grant"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="?attr/colorOnSurface" />

        <!-- Sub-hint about which permission option to pick. Visibility is
             flipped from TryItFragment based on hasMicPermission(): hidden
             once the user has granted, since past that point they only see
             this screen if they revisit. -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tryGrantHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="@string/onb_try_grant_hint"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:visibility="gone" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/tryResultCard"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="?attr/colorSurfaceVariant"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <ScrollView
                android:id="@+id/tryResultScroll"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:overScrollMode="never">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tryResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:text="@string/onb_try_result_placeholder"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </ScrollView>
        </com.google.android.material.card.MaterialCardView>

        <!-- Appears after the first recognised segment in this visit. Lives
             below the result card so it doesn't fight with the top hint
             («Говорите…»), which stays focused on what the user should
             physically do right now. -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tryDoneLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/onb_try_done"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="?attr/colorPrimary"
            android:visibility="gone" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tryOpenSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:padding="8dp"
            android:text="@string/onb_try_open_settings"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?attr/colorPrimary"
            android:visibility="gone" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
